# vps-telegram-watchdog configuration
# Copy to /etc/vps-watchdog/config.env and chmod 600 (it holds your bot token).

# --- Telegram (required) ------------------------------------------------------
# Create a bot with @BotFather, then get your chat id from @userinfobot
# (or send your bot a message and read https://api.telegram.org/bot<TOKEN>/getUpdates).
TG_BOT_TOKEN=
TG_CHAT_ID=

# Extra chat ids allowed to control the interactive bot (space-separated, optional).
TG_ADMIN_IDS=""

# --- Health checks (every 5 min) ----------------------------------------------
# Alert when / usage reaches this percentage.
DISK_THRESHOLD=85

# Re-send an alert for a still-failing check after this many hours.
RE_ALERT_HOURS=6

# PM2 monitoring: auto = monitor if pm2 is installed, yes, or no.
MONITOR_PM2=auto
# Space-separated PM2 process names to watch. Empty = all processes.
PM2_PROCESSES=""

# Space-separated systemd services to watch, e.g. "nginx postgresql docker".
SYSTEMD_SERVICES=""

# Space-separated domains with Let's Encrypt certs to watch for expiry,
# e.g. "example.com www.example.org". Looks in /etc/letsencrypt/live/<domain>/.
TLS_DOMAINS=""
TLS_CERT_WARN_DAYS=14

# Optional: alert when memory usage reaches this percentage. Empty = disabled.
MEM_THRESHOLD=

# --- SSH login alerts ----------------------------------------------------------
# File with one trusted IP per line; logins from other IPs are flagged 🚨.
# Manage it from the Telegram bot menu (Whitelist) or edit by hand.
KNOWN_IPS_FILE=/etc/vps-watchdog/known-ips

# --- Integrity check (hourly) ---------------------------------------------------
# Extra files to fingerprint, space-separated (added to the built-in list of
# passwd/shadow/sudoers/sshd_config/crontabs/authorized_keys/nginx sites).
WATCH_FILES_EXTRA=""

# --- Interactive bot permissions -------------------------------------------------
# Let the bot restart PM2/systemd services from the menu (with confirmation).
ALLOW_SERVICE_RESTART=no
# Let the bot unban IPs from fail2ban.
ALLOW_FAIL2BAN_UNBAN=yes
