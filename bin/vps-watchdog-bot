#!/usr/bin/env python3
"""vps-watchdog-bot — interactive Telegram menu for the VPS watchdog.

Long-polls the Telegram Bot API (stdlib only, no pip packages) and offers a
screen-based menu: live status, IP whitelist management, recent SSH logins,
fail2ban view/unban, service status/restart, disk usage, alert muting, and
on-demand health/integrity checks.

Navigation model (Telegram best practices):
  * Slash commands registered via setMyCommands — they populate the native
    ☰ menu button next to the message input.
  * One message is the "app window": every inline-button tap edits it in
    place instead of posting new messages.
  * Every screen has a consistent nav row (🏠 Menu / 🔄 Refresh); destructive
    actions get a confirm step that returns to the parent screen.

Only the chat ids in TG_CHAT_ID / TG_ADMIN_IDS may use it; everyone else is
silently ignored. Runs as a systemd service (vps-watchdog-bot.service).
"""

import html
import ipaddress
import json
import os
import re
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.parse
import urllib.request

CONFIG_FILE = os.environ.get("VPS_WATCHDOG_CONFIG", "/etc/vps-watchdog/config.env")
STATE_DIR = "/var/lib/vps-watchdog"
OFFSET_FILE = os.path.join(STATE_DIR, "bot-offset")
MUTE_FILE = os.path.join(STATE_DIR, "mute-until")


# --------------------------------------------------------------------------- config

def load_config():
    cfg = {}
    try:
        with open(CONFIG_FILE) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                k, _, v = line.partition("=")
                cfg[k.strip()] = v.strip().strip('"').strip("'")
    except OSError as e:
        sys.exit(f"cannot read {CONFIG_FILE}: {e}")
    if not cfg.get("TG_BOT_TOKEN") or not cfg.get("TG_CHAT_ID"):
        sys.exit(f"TG_BOT_TOKEN / TG_CHAT_ID not set in {CONFIG_FILE}")
    return cfg


CFG = load_config()
TOKEN = CFG["TG_BOT_TOKEN"]
ADMIN_IDS = {CFG["TG_CHAT_ID"]} | set(CFG.get("TG_ADMIN_IDS", "").split())
KNOWN_IPS_FILE = CFG.get("KNOWN_IPS_FILE", "/etc/vps-watchdog/known-ips")
ALLOW_RESTART = CFG.get("ALLOW_SERVICE_RESTART", "no").lower() == "yes"
ALLOW_UNBAN = CFG.get("ALLOW_FAIL2BAN_UNBAN", "yes").lower() == "yes"
API = f"https://api.telegram.org/bot{TOKEN}"
HOST = os.uname().nodename.split(".")[0]

# chat_id -> pending action (e.g. "add_ip")
PENDING = {}

e = html.escape


# --------------------------------------------------------------------------- telegram api

def api_call(method, params=None, timeout=60):
    data = urllib.parse.urlencode(params or {}).encode()
    req = urllib.request.Request(f"{API}/{method}", data=data)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return json.loads(resp.read().decode())
    except urllib.error.HTTPError as err:
        try:
            return json.loads(err.read().decode())
        except Exception:
            print(f"api {method} failed: {err}", file=sys.stderr)
            return None
    except (urllib.error.URLError, OSError, json.JSONDecodeError) as err:
        print(f"api {method} failed: {err}", file=sys.stderr)
        return None


def _msg_params(chat_id, text, keyboard):
    params = {"chat_id": chat_id, "text": text[:4000], "parse_mode": "HTML",
              "disable_web_page_preview": "true"}
    if keyboard:
        params["reply_markup"] = json.dumps({"inline_keyboard": keyboard})
    return params


def send(chat_id, text, keyboard=None):
    params = _msg_params(chat_id, text, keyboard)
    r = api_call("sendMessage", params, timeout=20)
    if r and not r.get("ok") and "parse" in r.get("description", "").lower():
        params.pop("parse_mode")  # malformed HTML — deliver as plain text
        r = api_call("sendMessage", params, timeout=20)
    return r


def edit(chat_id, message_id, text, keyboard=None):
    params = _msg_params(chat_id, text, keyboard)
    params["message_id"] = message_id
    r = api_call("editMessageText", params, timeout=20)
    if r and not r.get("ok"):
        desc = r.get("description", "")
        if "not modified" in desc:
            return  # Refresh with identical content — nothing to do
        if "parse" in desc.lower():
            params.pop("parse_mode")
            r = api_call("editMessageText", params, timeout=20)
            if r and r.get("ok"):
                return
        send(chat_id, text, keyboard)  # message too old / deleted


def answer_cb(cb_id, text=""):
    api_call("answerCallbackQuery", {"callback_query_id": cb_id, "text": text[:190]},
             timeout=10)


def delete(chat_id, message_id):
    """Delete the app-window message; Telegram refuses after ~48h."""
    r = api_call("deleteMessage", {"chat_id": chat_id, "message_id": message_id},
                 timeout=10)
    return bool(r and r.get("ok"))


# --------------------------------------------------------------------------- shell helpers

def sh(cmd, timeout=30):
    """Run a shell command, return stdout ('' on any failure)."""
    try:
        r = subprocess.run(cmd, shell=True, capture_output=True, text=True,
                           timeout=timeout)
        return r.stdout.strip()
    except (subprocess.TimeoutExpired, OSError):
        return ""


def have(binary):
    return shutil.which(binary) is not None


def header(title):
    return (f"<b>{e(title)}</b> — <code>{e(HOST)}</code>\n"
            f"🕒 {time.strftime('%Y-%m-%d %H:%M %Z')}\n")


def pre(text, limit=1500):
    body = text[:limit] + ("\n…" if len(text) > limit else "")
    return f"<pre>{e(body)}</pre>"


# --------------------------------------------------------------------------- whitelist storage

def read_ips():
    try:
        with open(KNOWN_IPS_FILE) as f:
            return [l.strip() for l in f if l.strip() and not l.strip().startswith("#")]
    except OSError:
        return []


def add_ip(ip):
    os.makedirs(os.path.dirname(KNOWN_IPS_FILE), exist_ok=True)
    with open(KNOWN_IPS_FILE, "a") as f:
        f.write(ip + "\n")


def remove_ip(ip):
    """Drop only the matching IP line; comments and other lines survive."""
    try:
        with open(KNOWN_IPS_FILE) as f:
            lines = f.readlines()
    except OSError:
        return
    kept = [l for l in lines if l.strip() != ip]
    tmp = KNOWN_IPS_FILE + ".tmp"
    with open(tmp, "w") as f:
        f.writelines(kept)
    os.replace(tmp, KNOWN_IPS_FILE)


def valid_ip(s):
    try:
        ipaddress.ip_address(s)
        return True
    except ValueError:
        return False


# --------------------------------------------------------------------------- mute storage

def mute_status():
    try:
        until = int(open(MUTE_FILE).read().strip())
    except (OSError, ValueError):
        return ""
    if until > time.time():
        return f"🔇 Alerts muted until {time.strftime('%H:%M %Z', time.localtime(until))}"
    return ""


def set_mute(seconds):
    os.makedirs(STATE_DIR, exist_ok=True)
    if seconds <= 0:
        try:
            os.remove(MUTE_FILE)
        except OSError:
            pass
        return "🔔 Alerts unmuted."
    with open(MUTE_FILE, "w") as f:
        f.write(str(int(time.time()) + seconds))
    return f"🔇 Alerts muted for {seconds // 3600}h."


# --------------------------------------------------------------------------- screens
# Every screen function returns (text, action_rows). The router appends the
# nav row and dispatches by name, so commands and callbacks share one path.

def service_lines():
    out = []
    if have("pm2"):
        raw = sh("pm2 jlist", timeout=20)
        try:
            for p in json.loads(raw or "[]"):
                st = (p.get("pm2_env") or {}).get("status", "?")
                emoji = "🟢" if st == "online" else "🔴"
                out.append(f"{emoji} pm2/{p.get('name', '?')} ({st})")
        except json.JSONDecodeError:
            out.append("❓ pm2: unreadable")
    for svc in CFG.get("SYSTEMD_SERVICES", "").split():
        st = sh(f"systemctl is-active {svc}") or "unknown"
        emoji = "🟢" if st == "active" else "🔴"
        out.append(f"{emoji} systemd/{svc} ({st})")
    return out


def scr_menu():
    text = header("🤖 VPS Watchdog") + "\nPick a screen — or use the ☰ menu next to the input box."
    m = mute_status()
    if m:
        text += f"\n\n{m}"
    kb = [
        [{"text": "📊 Status", "callback_data": "nav:status"},
         {"text": "💾 Disk", "callback_data": "nav:disk"}],
        [{"text": "🌐 Whitelist", "callback_data": "nav:whitelist"},
         {"text": "👥 Logins", "callback_data": "nav:logins"}],
        [{"text": "🛡 fail2ban", "callback_data": "nav:fail2ban"},
         {"text": "⚙️ Services", "callback_data": "nav:services"}],
        [{"text": "▶️ Run checks", "callback_data": "nav:checks"},
         {"text": "🔇 Mute", "callback_data": "nav:mute"}],
        [{"text": "ℹ️ Help", "callback_data": "nav:help"},
         {"text": "❌ Close", "callback_data": "close"}],
    ]
    return text, kb


def scr_status():
    up = sh("uptime -p").replace("up ", "")
    disk = sh("df -h / | tail -1 | awk '{print $3\"/\"$2\" (\"$5\")\"}'")
    mem = sh("free -h | awk '/Mem:/ {print $3\"/\"$2}'")
    mem_pct = sh("free | awk '/Mem:/ {printf \"%d\", $3/$2*100}'")
    load = sh("awk '{print $1\", \"$2\", \"$3}' /proc/loadavg")
    sessions = sh("who | wc -l")

    lines = [header("📊 Live status"),
             f"⏱ Uptime: {e(up)}",
             f"💾 Disk /: {e(disk)}",
             f"🧠 Mem: {e(mem)} ({e(mem_pct)}%)  •  📈 Load: {e(load)}",
             f"👥 Active SSH sessions: {e(sessions)}"]

    svc = service_lines()
    if svc:
        lines += ["", "<b>Services</b>"] + [e(s) for s in svc]

    for domain in CFG.get("TLS_DOMAINS", "").split():
        cert = f"/etc/letsencrypt/live/{domain}/fullchain.pem"
        if os.path.isfile(cert):
            end = sh(f"date -d \"$(openssl x509 -in {cert} -noout -enddate | cut -d= -f2)\" +%s")
            if end.isdigit():
                days = (int(end) - int(time.time())) // 86400
                emoji = "🔐" if days > 14 else "🚨"
                lines.append(f"{emoji} TLS {e(domain)}: {days} days left")

    if have("fail2ban-client"):
        banned = sh("fail2ban-client status sshd 2>/dev/null | awk -F'\\t+' '/Currently banned/ {print $2}'")
        lines.append(f"🛡 fail2ban (sshd): {e(banned or '0')} banned now")

    m = mute_status()
    if m:
        lines += ["", m]
    return "\n".join(lines), []


def scr_disk():
    df = sh("df -h / /var 2>/dev/null | sort -u")
    top = sh("du -sh /var/log /var/lib /opt /home /tmp 2>/dev/null | sort -rh | head -6")
    text = (header("💾 Disk") + "\n" + pre(df)
            + "\n<b>Top consumers</b>\n" + pre(top))
    return text, []


def scr_whitelist():
    ips = read_ips()
    text = header("🌐 IP whitelist")
    text += "\nLogins from these IPs alert as ✅ trusted; all others as 🚨 unknown.\n\n"
    text += "\n".join(f"• <code>{e(ip)}</code>" for ip in ips) if ips else "<i>(empty)</i>"
    kb = [[{"text": f"🗑 remove {ip}", "callback_data": f"wl_rm:{ip}"}] for ip in ips[:20]]
    kb.append([{"text": "➕ Add IP", "callback_data": "wl_add"}])
    return text, kb


def scr_logins():
    raw = sh("grep -E 'Accepted (password|publickey)' /var/log/auth.log | tail -8")
    known = set(read_ips())
    rows = []
    for l in raw.splitlines():
        m = re.search(r"^(\S+\s+\S+\s+\S+).*Accepted (\w+) for (\S+) from (\S+)", l)
        if m:
            ts, method, user, ip = m.groups()
            mark = "✅" if ip in known else "🚨"
            rows.append(f"{mark} {e(ts)} — <b>{e(user)}</b> from <code>{e(ip)}</code> ({e(method)})")
    text = header("👥 Recent SSH logins") + "\n"
    text += "\n".join(rows) if rows else "<i>(none in current auth.log)</i>"
    active = sh("who")
    text += "\n\n<b>Active now</b>\n" + (pre(active) if active else "<i>(none)</i>")
    return text, []


def scr_fail2ban():
    if not have("fail2ban-client"):
        return header("🛡 fail2ban") + "\nfail2ban is not installed.", []
    raw = sh("fail2ban-client status sshd 2>/dev/null")
    banned = re.search(r"Banned IP list:\s*(.*)", raw)
    ips = banned.group(1).split() if banned else []
    text = header("🛡 fail2ban (sshd)") + "\n" + pre(raw or "(no output)")
    kb = []
    if ALLOW_UNBAN:
        kb = [[{"text": f"🔓 unban {ip}", "callback_data": f"f2b_unban:{ip}"}] for ip in ips[:15]]
    return text, kb


def scr_services():
    lines = service_lines()
    text = header("⚙️ Services") + "\n"
    text += "\n".join(e(s) for s in lines) if lines else "<i>(none detected/configured)</i>"
    kb = []
    if ALLOW_RESTART:
        if have("pm2"):
            raw = sh("pm2 jlist", timeout=20)
            try:
                for p in json.loads(raw or "[]"):
                    n = p.get("name", "?")
                    kb.append([{"text": f"🔄 restart pm2/{n}", "callback_data": f"svc_ask:pm2:{n}"}])
            except json.JSONDecodeError:
                pass
        for svc in CFG.get("SYSTEMD_SERVICES", "").split():
            kb.append([{"text": f"🔄 restart {svc}", "callback_data": f"svc_ask:sysd:{svc}"}])
    else:
        text += ("\n\n<i>Restarts are disabled — set ALLOW_SERVICE_RESTART=yes "
                 "in the config to enable them.</i>")
    return text, kb


def scr_checks():
    sh("/usr/local/bin/vps-healthcheck", timeout=120)
    sh("/usr/local/bin/vps-integrity-check", timeout=120)
    text = (header("▶️ Checks complete")
            + "\nHealth + integrity checks ran just now. Any OK→FAIL transition "
              "or integrity change was alerted separately — silence means all good.")
    return text, []


def scr_mute():
    text = header("🔇 Mute alerts")
    text += "\nSuppress cron/PAM alerts; this menu keeps working.\n\n"
    text += mute_status() or "🔔 Alerts are ON."
    kb = [[{"text": "1h", "callback_data": "mute:3600"},
           {"text": "6h", "callback_data": "mute:21600"},
           {"text": "24h", "callback_data": "mute:86400"},
           {"text": "🔔 Unmute", "callback_data": "mute:0"}]]
    return text, kb


def scr_help():
    cmds = "\n".join(f"/{c} — {e(d)}" for c, d in COMMANDS)
    text = (header("ℹ️ Help")
            + "\nThis bot is the remote control for the VPS watchdog: cron jobs "
              "alert on service/disk/memory/TLS problems and file tampering, PAM "
              "alerts on every SSH login, and this menu lets you inspect the box "
              "and manage the trusted-IP whitelist.\n\n<b>Commands</b>\n" + cmds
            + "\n\nButtons edit this message in place — use ☰ next to the input "
              "box or /menu to come back here. ❌ Close on the main menu "
              "dismisses this message from the chat.")
    return text, []


SCREENS = {
    "menu": scr_menu, "status": scr_status, "disk": scr_disk,
    "whitelist": scr_whitelist, "logins": scr_logins, "fail2ban": scr_fail2ban,
    "services": scr_services, "checks": scr_checks, "mute": scr_mute,
    "help": scr_help,
}

COMMANDS = [
    ("menu", "Main menu"),
    ("status", "Live system status"),
    ("disk", "Disk usage and top consumers"),
    ("whitelist", "Manage trusted SSH IPs"),
    ("logins", "Recent SSH logins"),
    ("fail2ban", "Banned IPs, unban"),
    ("services", "Service status, restart"),
    ("checks", "Run health and integrity checks now"),
    ("mute", "Mute or unmute alerts"),
    ("help", "What this bot does"),
]


def render(name):
    """Screen name -> (text, full keyboard incl. nav row)."""
    text, kb = SCREENS[name]()
    kb = list(kb)
    if name == "menu":
        return text, kb
    nav = [{"text": "🏠 Menu", "callback_data": "nav:menu"}]
    if name != "checks":  # re-running checks via Refresh would be surprising
        nav.append({"text": "🔄 Refresh", "callback_data": f"nav:{name}"})
    kb.append(nav)
    return text, kb


def show(chat_id, name, msg_id=None):
    """Edit the current app-window message, or send a fresh one for commands."""
    text, kb = render(name)
    if msg_id:
        edit(chat_id, msg_id, text, kb)
    else:
        send(chat_id, text, kb)


# --------------------------------------------------------------------------- dispatch

def handle_callback(cb):
    chat_id = str(cb["message"]["chat"]["id"])
    msg_id = cb["message"]["message_id"]
    data = cb.get("data", "")
    answer_cb(cb["id"], "Running checks…" if data == "nav:checks" else "")

    if data == "close":
        PENDING.pop(chat_id, None)
        if not delete(chat_id, msg_id):
            # Too old to delete — collapse to a stub with no keyboard instead.
            edit(chat_id, msg_id,
                 header("🤖 VPS Watchdog") + "\nMenu closed — send /menu to reopen.")
    elif data.startswith("nav:"):
        name = data.split(":", 1)[1]
        if name in SCREENS:
            PENDING.pop(chat_id, None)
            show(chat_id, name, msg_id)
    elif data == "wl_add":
        PENDING[chat_id] = "add_ip"
        edit(chat_id, msg_id,
             header("🌐 IP whitelist") + "\n➕ Send the IP address to whitelist "
             "(IPv4 or IPv6) as a message.\nSend /cancel to abort.",
             [[{"text": "⬅️ Back", "callback_data": "nav:whitelist"}]])
    elif data.startswith("wl_rm:"):
        ip = data.split(":", 1)[1]
        if ip in read_ips():
            remove_ip(ip)
            answer_cb(cb["id"], f"Removed {ip}")
        show(chat_id, "whitelist", msg_id)
    elif data.startswith("f2b_unban:") and ALLOW_UNBAN:
        ip = data.split(":", 1)[1]
        if valid_ip(ip):
            sh(f"fail2ban-client set sshd unbanip {ip}")
            answer_cb(cb["id"], f"Unbanned {ip}")
        show(chat_id, "fail2ban", msg_id)
    elif data.startswith("svc_ask:") and ALLOW_RESTART:
        _, kind, name = data.split(":", 2)
        edit(chat_id, msg_id,
             header("⚙️ Services") + f"\n⚠️ Restart <b>{e(kind)}/{e(name)}</b> — are you sure?",
             [[{"text": "✅ Yes, restart", "callback_data": f"svc_do:{kind}:{name}"},
               {"text": "❌ No", "callback_data": "nav:services"}]])
    elif data.startswith("svc_do:") and ALLOW_RESTART:
        _, kind, name = data.split(":", 2)
        if re.fullmatch(r"[A-Za-z0-9@._-]+", name):
            if kind == "pm2":
                sh(f"pm2 restart {name}", timeout=60)
            else:
                sh(f"systemctl restart {name}", timeout=60)
            time.sleep(2)
        show(chat_id, "services", msg_id)
    elif data.startswith("mute:"):
        answer_cb(cb["id"], set_mute(int(data.split(":")[1])))
        show(chat_id, "mute", msg_id)


def handle_message(msg):
    chat_id = str(msg["chat"]["id"])
    text = (msg.get("text") or "").strip()

    if text == "/cancel":
        PENDING.pop(chat_id, None)
        show(chat_id, "menu")
        return

    if PENDING.get(chat_id) == "add_ip":
        PENDING.pop(chat_id, None)
        if not valid_ip(text):
            send(chat_id, f"❌ <code>{e(text[:60])}</code> is not a valid IP address.",
                 [[{"text": "➕ Try again", "callback_data": "wl_add"},
                   {"text": "🏠 Menu", "callback_data": "nav:menu"}]])
            return
        if text not in read_ips():
            add_ip(text)
        show(chat_id, "whitelist")
        return

    cmd = text.split()[0].lstrip("/").split("@")[0].lower() if text.startswith("/") else ""
    if cmd in SCREENS:
        show(chat_id, cmd)
    elif cmd in ("start", "help"):
        show(chat_id, "help" if cmd == "help" else "menu")
    else:
        show(chat_id, "menu")


# --------------------------------------------------------------------------- main loop

def register_commands():
    """Populate the native ☰ menu button next to the message input."""
    api_call("setMyCommands", {
        "commands": json.dumps([{"command": c, "description": d} for c, d in COMMANDS]),
    }, timeout=20)
    api_call("setChatMenuButton", {
        "menu_button": json.dumps({"type": "commands"}),
    }, timeout=20)


def load_offset():
    try:
        return int(open(OFFSET_FILE).read().strip())
    except (OSError, ValueError):
        return 0


def save_offset(offset):
    os.makedirs(STATE_DIR, exist_ok=True)
    with open(OFFSET_FILE, "w") as f:
        f.write(str(offset))


def main():
    print(f"vps-watchdog-bot starting (admins: {', '.join(sorted(ADMIN_IDS))})")
    register_commands()
    offset = load_offset()
    while True:
        resp = api_call("getUpdates", {"offset": offset + 1, "timeout": 50},
                        timeout=70)
        if not resp or not resp.get("ok"):
            time.sleep(5)
            continue
        for upd in resp.get("result", []):
            offset = max(offset, upd["update_id"])
            save_offset(offset)
            try:
                if "callback_query" in upd:
                    cb = upd["callback_query"]
                    if str(cb["message"]["chat"]["id"]) in ADMIN_IDS:
                        handle_callback(cb)
                    else:
                        answer_cb(cb["id"], "unauthorized")
                elif "message" in upd:
                    if str(upd["message"]["chat"]["id"]) in ADMIN_IDS:
                        handle_message(upd["message"])
            except Exception as err:  # keep the loop alive on any handler bug
                print(f"handler error: {err}", file=sys.stderr)


if __name__ == "__main__":
    main()
