#!/bin/bash
# vps-healthcheck вАФ runs every 5 min via /etc/cron.d/vps-watchdog.
# Alerts to Telegram on state transitions OK<->FAIL for:
#   1. PM2 processes online (if enabled/installed)
#   2. Configured systemd services active
#   3. Disk usage on / under DISK_THRESHOLD
#   4. Memory usage under MEM_THRESHOLD (if set)
#   5. TLS certs for TLS_DOMAINS with >TLS_CERT_WARN_DAYS remaining
# Persistent failures re-alert every RE_ALERT_HOURS. State in /var/lib/vps-watchdog.

set -u
ENV_FILE=${VPS_WATCHDOG_CONFIG:-/etc/vps-watchdog/config.env}
# shellcheck disable=SC1090
[ -r "$ENV_FILE" ] && . "$ENV_FILE"

# Serialize runs (cron + on-demand from the bot can overlap).
exec 9>/run/vps-healthcheck.lock
flock -n 9 || exit 0

STATE_DIR=/var/lib/vps-watchdog
STATE_FILE="$STATE_DIR/state"
HOST=$(hostname -s)
mkdir -p "$STATE_DIR"
chmod 700 "$STATE_DIR"
touch "$STATE_FILE"

DISK_THRESHOLD=${DISK_THRESHOLD:-85}
RE_ALERT_SECS=$(( ${RE_ALERT_HOURS:-6} * 3600 ))
MONITOR_PM2=${MONITOR_PM2:-auto}
PM2_PROCESSES=${PM2_PROCESSES:-}
SYSTEMD_SERVICES=${SYSTEMD_SERVICES:-}
TLS_DOMAINS=${TLS_DOMAINS:-}
TLS_CERT_WARN_DAYS=${TLS_CERT_WARN_DAYS:-14}
MEM_THRESHOLD=${MEM_THRESHOLD:-}
NOW=$(date +%s)

notify() { /usr/local/bin/tg-notify "$1" || true; }

prev_state() { grep -E "^${1}=" "$STATE_FILE" 2>/dev/null | tail -1 | cut -d= -f2-; }
prev_time()  { grep -E "^${1}_t=" "$STATE_FILE" 2>/dev/null | tail -1 | cut -d= -f2-; }
write_state() {
  local k=$1 v=$2 t=$3
  grep -vE "^${k}(_t)?=" "$STATE_FILE" 2>/dev/null > "$STATE_FILE.tmp" || true
  printf '%s=%s\n%s_t=%s\n' "$k" "$v" "$k" "$t" >> "$STATE_FILE.tmp"
  mv "$STATE_FILE.tmp" "$STATE_FILE"
}

handle() {
  # Keys become grep patterns and state-file fields вАФ strip anything unsafe
  # (service names like postgresql@14-main, domains with dots).
  local key; key=$(printf '%s' "$1" | tr -c 'A-Za-z0-9_' '_')
  local new=$2 fail_msg=$3 ok_msg=$4
  local old; old=$(prev_state "$key")
  local last_t; last_t=$(prev_time "$key")
  [ -z "$old" ] && old=OK

  if [ "$old" != "$new" ]; then
    if [ "$new" = "FAIL" ]; then notify "$fail_msg"; else notify "$ok_msg"; fi
    write_state "$key" "$new" "$NOW"
  elif [ "$new" = "FAIL" ] && [ -n "$last_t" ] && [ $((NOW - last_t)) -ge $RE_ALERT_SECS ]; then
    notify "рЯФБ [reminder] $fail_msg"
    write_state "$key" "$new" "$NOW"
  fi
}

# 1. PM2 ----------------------------------------------------------------------
PM2_ENABLED=no
case "$MONITOR_PM2" in
  yes) PM2_ENABLED=yes ;;
  auto) command -v pm2 >/dev/null 2>&1 && PM2_ENABLED=yes ;;
esac

if [ "$PM2_ENABLED" = "yes" ]; then
  PM2_OUT=$(pm2 jlist 2>/dev/null || echo "[]")
  PM2_REPORT=$(echo "$PM2_OUT" | WATCH="$PM2_PROCESSES" python3 -c '
import sys, json, os
watch = set(os.environ.get("WATCH", "").split())
try:
  data = json.load(sys.stdin)
except Exception:
  print("PARSE_ERROR|"); sys.exit(0)
lines, bad, seen = [], [], set()
for p in data:
  name = p.get("name", "?")
  if watch and name not in watch:
    continue
  seen.add(name)
  st = (p.get("pm2_env") or {}).get("status", "?")
  restarts = (p.get("pm2_env") or {}).get("restart_time", 0)
  emoji = "рЯЯҐ" if st == "online" else "рЯФі"
  lines.append("{} {} ({}, вЖЇ{})".format(emoji, name, st, restarts))
  if st != "online":
    bad.append("{}={}".format(name, st))
for w in sorted(watch - seen):
  lines.append("рЯФі {} (missing)".format(w)); bad.append("{}=missing".format(w))
status = "OK" if not bad else "FAIL"
print("{}|{}|{}".format(status, ", ".join(bad), "\n".join(lines)))
' 2>/dev/null)

  PM2_STATUS=${PM2_REPORT%%|*}
  PM2_REST=${PM2_REPORT#*|}
  PM2_DOWN=${PM2_REST%%|*}
  PM2_DETAILS=${PM2_REST#*|}

  # An empty process list is only "cannot read" when the user explicitly
  # opted in (MONITOR_PM2=yes) or named processes to watch (missing-detection
  # covers that case); with auto + no watch list, an empty pm2 is not an error.
  EMPTY_IS_FAIL=no
  [ "$MONITOR_PM2" = "yes" ] && [ -z "$PM2_PROCESSES" ] && EMPTY_IS_FAIL=yes

  if [ "$PM2_STATUS" = "PARSE_ERROR" ] || [ -z "$PM2_OUT" ] || \
     { [ "$EMPTY_IS_FAIL" = "yes" ] && [ "$PM2_OUT" = "[]" ]; }; then
    handle pm2 FAIL \
      "рЯЪ® VPS ALERT вАФ $HOST
рЯФі PM2: cannot read process list
вАҐ 'pm2 jlist' returned empty/error
вАҐ Action: SSH in and run 'pm2 status'" \
      "вЬЕ VPS RECOVERED вАФ $HOST
рЯЯҐ PM2 process list readable again"
  elif [ "$PM2_STATUS" = "FAIL" ]; then
    handle pm2 FAIL \
      "рЯЪ® VPS ALERT вАФ $HOST
рЯФі PM2 service offline
вАҐ Down: $PM2_DOWN
вАҐ Status:
$PM2_DETAILS
вАҐ Action: pm2 logs --err --lines 30" \
      "вЬЕ VPS RECOVERED вАФ $HOST
рЯЯҐ PM2 services back online
$PM2_DETAILS"
  else
    handle pm2 OK "" \
      "вЬЕ VPS RECOVERED вАФ $HOST
рЯЯҐ PM2 services back online
$PM2_DETAILS"
  fi
fi

# 2. systemd services -----------------------------------------------------------
for SVC in $SYSTEMD_SERVICES; do
  ST=$(systemctl is-active "$SVC" 2>&1)
  if [ "$ST" = "active" ]; then
    handle "svc_$SVC" OK "" \
      "вЬЕ VPS RECOVERED вАФ $HOST
рЯЯҐ systemd: $SVC active again"
  else
    handle "svc_$SVC" FAIL \
      "рЯЪ® VPS ALERT вАФ $HOST
рЯФі systemd: $SVC is $ST
вАҐ Action: journalctl -u $SVC -n 30" \
      "вЬЕ VPS RECOVERED вАФ $HOST
рЯЯҐ systemd: $SVC active again"
  fi
done

# 3. Disk ---------------------------------------------------------------------
USED=$(df --output=pcent / | tail -1 | tr -dc '0-9')
DISK_LINE=$(df -h / | tail -1 | awk '{print $3"/"$2" used ("$5"), "$4" free"}')

if [ "${USED:-0}" -ge "$DISK_THRESHOLD" ]; then
  # du is expensive вАФ only walk the tree when we're actually over threshold
  TOP_DIRS=$(du -sh /var/log /var/lib /opt /home /tmp 2>/dev/null | sort -rh | head -3 | awk '{print "  вАҐ " $0}')
  handle disk FAIL \
    "рЯЪ® VPS ALERT вАФ $HOST
рЯТЊ Disk near full
вАҐ /: $DISK_LINE
вАҐ Top consumers:
$TOP_DIRS
вАҐ Action: investigate the top consumers above" \
    "вЬЕ VPS RECOVERED вАФ $HOST
рЯТЊ Disk: / back below ${DISK_THRESHOLD}%
вАҐ /: $DISK_LINE"
else
  handle disk OK "" \
    "вЬЕ VPS RECOVERED вАФ $HOST
рЯТЊ Disk: / back below ${DISK_THRESHOLD}%
вАҐ /: $DISK_LINE"
fi

# 4. Memory (optional) -----------------------------------------------------------
if [ -n "$MEM_THRESHOLD" ]; then
  MEM_PCT=$(free | awk '/Mem:/ {printf "%d", $3/$2*100}')
  MEM_LINE=$(free -h | awk '/Mem:/ {print $3"/"$2}')
  if [ "${MEM_PCT:-0}" -ge "$MEM_THRESHOLD" ]; then
    handle mem FAIL \
      "рЯЪ® VPS ALERT вАФ $HOST
рЯІ† Memory usage high
вАҐ Used: $MEM_LINE (${MEM_PCT}%)
вАҐ Action: ps aux --sort=-%mem | head" \
      "вЬЕ VPS RECOVERED вАФ $HOST
рЯІ† Memory back below ${MEM_THRESHOLD}% ($MEM_LINE)"
  else
    handle mem OK "" \
      "вЬЕ VPS RECOVERED вАФ $HOST
рЯІ† Memory back below ${MEM_THRESHOLD}% ($MEM_LINE)"
  fi
fi

# 5. TLS certs -----------------------------------------------------------------
for DOMAIN in $TLS_DOMAINS; do
  CERT="/etc/letsencrypt/live/$DOMAIN/fullchain.pem"
  [ -r "$CERT" ] || continue
  END_EPOCH=$(date -d "$(openssl x509 -in "$CERT" -noout -enddate | cut -d= -f2)" +%s 2>/dev/null || echo 0)
  [ "$END_EPOCH" -gt 0 ] || continue
  DAYS=$(( (END_EPOCH - NOW) / 86400 ))
  EXPIRY_DATE=$(date -d "@$END_EPOCH" '+%Y-%m-%d')
  TIMER_STATE=$(systemctl is-active certbot.timer 2>&1)
  if [ "$DAYS" -le "$TLS_CERT_WARN_DAYS" ]; then
    handle "cert_$DOMAIN" FAIL \
      "рЯЪ® VPS ALERT вАФ $HOST
рЯФР TLS cert expiring soon
вАҐ Domain: $DOMAIN
вАҐ Days left: $DAYS (expires $EXPIRY_DATE)
вАҐ certbot.timer: $TIMER_STATE
вАҐ Action: certbot renew --dry-run; check journalctl -u certbot" \
      "вЬЕ VPS RECOVERED вАФ $HOST
рЯФР TLS cert renewed ($DOMAIN)
вАҐ Days left: $DAYS"
  else
    handle "cert_$DOMAIN" OK "" \
      "вЬЕ VPS RECOVERED вАФ $HOST
рЯФР TLS cert renewed ($DOMAIN)
вАҐ Days left: $DAYS"
  fi
done
